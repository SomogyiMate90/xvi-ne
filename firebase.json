{
  "hosting": {
    "public": "build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "src/**"
    ],
    "rewrites": [
      {
        "source": "**/*.{php*,PhP*,asp*,aspx*,jsp*,cgi*,env*,sql*,bak*,log*,ini*,config*,git*}",
        "function": "blockRobots",
        "region": "europe-central2"
      },
      {
        "source": "/@(wp|wordpress)*{,/**}",
        "function": "blockRobots",
        "region": "europe-central2"
      },
      {
        "source": "/@(phpmyadmin|pma|mysql|dbadmin){,/**}",
        "function": "blockRobots",
        "region": "europe-central2"
      },
      {
        "source": "/@(admin|administrator|register|login|controlpanel|cpanel|webadmin|panel){,/**}",
        "function": "blockRobots",
        "region": "europe-central2"
      },
      {
        "source": "/@(setup|install|installer|vendor){,/**}",
        "function": "blockRobots",
        "region": "europe-central2"
      },
      {
        "source": "/@(xmlrpc|.env|.git|.svn){,/**}",
        "function": "blockRobots",
        "region": "europe-central2"
      },
      {
        "source": "/@(oldal|esemeny|Home|home|hireink|ado-1){,/**}",
        "function": "blockRobots",
        "region": "europe-central2"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ]
    }
  ],
   "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 6000
    },
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  }
}
